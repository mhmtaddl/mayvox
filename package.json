{
  "name": "caylaklar-sesli-sohbet",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node --eval \"require('fs').rmSync('./dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"node server.cjs\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "electron:build": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "server:start": "node server.cjs"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.20",
    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "livekit-client": "^2.17.3",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.6",
    "uiohook-napi": "^1.5.4",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.caylaklar.seslisohbet",
    "productName": "CylkSohbet",
    "copyright": "Bir Caylak",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**"
    ],
    "icon": "build/icon.ico",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "CylkSohbet.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "mhmtaddl",
      "repo": "caylaklar-sesli-sohbet"
    }
  }
}
