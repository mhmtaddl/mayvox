# PostgreSQL
DATABASE_URL=postgresql://postgres:<PASSWORD>@127.0.0.1:5433/postgres

# Server
PORT=4001
HOST=0.0.0.0
CORS_ORIGIN=https://mayvox.com,https://www.mayvox.com,https://cylksohbet.org,https://www.cylksohbet.org,http://localhost:3000,http://127.0.0.1:3000,capacitor://localhost
JWT_SECRET=change-me

# Realtime invite bridge (server-backend → chat-server)
# chat-server.cjs'in aynı host üzerinde çalıştığı adres. Prod'da localhost'ta kalmalı.
CHAT_SERVER_URL=http://127.0.0.1:10001
# chat-server ile PAYLAŞILAN secret. İKİ servis de aynı değeri okumalı.
# Tanımlı değilse invite realtime push devre dışı kalır (polling fallback çalışır).
# Üret: openssl rand -hex 32
INTERNAL_NOTIFY_SECRET=

# LiveKit (voice moderation: timeout drop + room kick)
# Üçü de boşsa moderation aksiyonları sadece DB'ye yazar — aktif katılımcıları düşüremez.
# cylk-token-server ile AYNI key/secret kullanılmalı.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
