{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "[console]::beep(800,150); [console]::beep(1000,150)"
          }
        ]
      }
    ]
  }
}
