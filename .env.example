# ─── CLIENT (Vite bundle'a gömülür — public, commit edilebilir) ───────────────

# Supabase project URL + anon key (public by design, RLS ile korunur)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# LiveKit WebSocket endpoint (public)
VITE_LIVEKIT_URL="wss://your-livekit-host:7880"

# Token server URL
# Yerel geliştirme: http://localhost:3001
# Production: .env.production dosyası bu değeri otomatik ezer — burada değiştirme
VITE_TOKEN_SERVER_URL="http://localhost:3001"

# ─── SERVER-ONLY (sadece server.cjs için — Render dashboard veya yerel .env) ──
# Bu değerler hiçbir zaman Electron/Vite bundle'a girmez.
# Production'da Render dashboard'dan env var olarak set edilir.

# Supabase — token server'ın JWT doğrulaması için (client ile aynı değerler)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# LiveKit admin kimlik bilgileri — ASLA istemci tarafına verme
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# Not: LIVEKIT_URL token server tarafından kullanılmaz.
# Token üretmek için yalnızca API key/secret gereklidir.
