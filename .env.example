# ─── CLIENT (Vite bundle'a gömülür — public, commit edilebilir) ───────────────

# Supabase project URL + anon key (public by design, RLS ile korunur)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# LiveKit WebSocket endpoint (public)
VITE_LIVEKIT_URL="wss://your-project.livekit.cloud"

# Token server URL
# Local dev: http://localhost:3001
# Production: .env.production dosyası bu değeri otomatik ezer — burada değiştirme
VITE_TOKEN_SERVER_URL="http://localhost:3001"

# ─── SERVER-ONLY (sadece local dev server.cjs için) ───────────────────────────
# Production'da bu değerler Render dashboard'dan env var olarak set edilir.
# Hiçbir zaman production build'e (installer'a) girmez.

LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
LIVEKIT_URL="wss://your-project.livekit.cloud"
